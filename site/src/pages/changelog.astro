---
import Layout from '../layouts/Layout.astro';
import { execSync } from 'node:child_process';

const gitLog = execSync(
  'git log --pretty=format:"%H|%ai|%s" --no-merges -50',
  { cwd: '..', encoding: 'utf-8' }
);

interface Commit {
  hash: string;
  date: string;
  message: string;
  type: string;
  scope: string;
  icon: string;
}

function parseCommit(line: string): Commit | null {
  const parts = line.split('|');
  if (parts.length < 3) return null;
  const hash = parts[0];
  const dateStr = parts[1];
  const message = parts.slice(2).join('|');

  const match = message.match(/^(\w+)(?:\(([^)]*)\))?:\s*(.+)/);
  const type = match ? match[1] : 'other';
  const scope = match ? (match[2] ?? '') : '';

  const iconMap: Record<string, string> = {
    feat: '✨', fix: '🔧', docs: '📝', chore: '🔩',
    refactor: '♻️', style: '🎨', test: '🧪', perf: '⚡', ci: '🚀', other: '📦',
  };

  return {
    hash: hash.slice(0, 7),
    date: dateStr.split(' ')[0],
    message, type, scope,
    icon: iconMap[type] ?? '📦',
  };
}

const commits = gitLog.split('\n').map(parseCommit).filter((c): c is Commit => c !== null);

const grouped = new Map<string, Commit[]>();
for (const commit of commits) {
  const existing = grouped.get(commit.date) ?? [];
  existing.push(commit);
  grouped.set(commit.date, existing);
}

const base = import.meta.env.BASE_URL;
---

<Layout title="업데이트 로그">
  <div class="changelog-header">
    <h1>업데이트 로그</h1>
    <p class="changelog-desc">프로젝트의 변경 이력입니다. push 시 자동으로 갱신됩니다.</p>
  </div>

  <div class="timeline">
    {[...grouped.entries()].map(([date, dayCommits]) => (
      <div class="day-group">
        <div class="day-header">
          <span class="day-dot" />
          <time>{date}</time>
        </div>
        <div class="day-commits">
          {dayCommits.map(commit => (
            <div class="commit-card">
              <span class="commit-icon">{commit.icon}</span>
              <div class="commit-body">
                <span class="commit-message">{commit.message}</span>
                <div class="commit-meta">
                  <code class="commit-hash">{commit.hash}</code>
                  {commit.scope && <span class="commit-scope">{commit.scope}</span>}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>

  <div class="back-link">
    <a href={base}>← 아이디어 목록으로</a>
  </div>
</Layout>

<style>
  .changelog-header { margin-bottom: 2.5rem; }
  .changelog-header h1 { font-size: 2rem; margin-bottom: 0.5rem; }
  .changelog-desc { color: var(--color-text-secondary); font-size: 0.95rem; }
  .timeline { position: relative; padding-left: 1.5rem; border-left: 2px solid var(--color-border); }
  .day-group { margin-bottom: 2rem; }
  .day-header { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem; margin-left: -1.65rem; }
  .day-dot { width: 12px; height: 12px; border-radius: 50%; background: var(--color-accent); border: 2px solid var(--color-bg); flex-shrink: 0; }
  .day-header time { font-weight: 600; font-size: 1rem; color: var(--color-text); }
  .day-commits { display: flex; flex-direction: column; gap: 0.5rem; }
  .commit-card { display: flex; gap: 0.75rem; padding: 0.75rem 1rem; background: var(--color-bg-card); border: 1px solid var(--color-border); border-radius: 8px; transition: background 0.15s; }
  .commit-card:hover { background: var(--color-bg-card-hover); }
  .commit-icon { font-size: 1.1rem; flex-shrink: 0; margin-top: 0.1rem; }
  .commit-body { flex: 1; min-width: 0; }
  .commit-message { font-size: 0.9rem; color: var(--color-text); line-height: 1.5; }
  .commit-meta { display: flex; gap: 0.5rem; margin-top: 0.35rem; align-items: center; }
  .commit-hash { font-size: 0.7rem; color: var(--color-text-muted); background: var(--color-bg); padding: 0.1rem 0.4rem; border-radius: 4px; }
  .commit-scope { font-size: 0.7rem; color: var(--color-accent); background: rgba(56, 189, 248, 0.1); padding: 0.1rem 0.5rem; border-radius: 10px; }
  .back-link { margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--color-border); }
  .back-link a { font-size: 0.9rem; }
</style>
