---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — Idea Bank</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Fira+Code:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body>
  <header class="header">
    <a href={base} class="logo">
      <span class="logo-icon">✦</span>
      Idea Bank
    </a>
    <span class="header-sub">zerovoids-cosmos · idea-generator-critic probe</span>
    <a href={`${base}changelog/`} class="header-changelog">업데이트 로그</a>
  </header>

  <main class="content">
    <slot />
  </main>
</body>
</html>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: var(--header-height);
    background: var(--color-bg-secondary);
    border-bottom: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    padding: 0 1.5rem;
    gap: 1rem;
    z-index: 100;
  }

  .logo {
    font-weight: 700;
    font-size: 1.1rem;
    color: #f1f5f9;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .logo:hover { color: var(--color-accent); }

  .logo-icon {
    color: var(--color-accent);
    font-size: 1.2rem;
  }

  .header-sub {
    color: var(--color-text-muted);
    font-size: 0.8rem;
  }

  .header-changelog {
    margin-left: auto;
    font-size: 0.8rem;
    color: var(--color-text-muted);
    padding: 0.3rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    transition: all 0.15s;
  }

  .header-changelog:hover {
    color: var(--color-text);
    border-color: var(--color-text-muted);
  }

  .content {
    padding-top: calc(var(--header-height) + 2rem);
    padding-left: 2rem;
    padding-right: 2rem;
    padding-bottom: 3rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  @media (max-width: 768px) {
    .content { padding: calc(var(--header-height) + 1rem) 1rem 2rem; }
    .header-sub { display: none; }
  }
</style>
